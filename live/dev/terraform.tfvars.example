# Optional local overrides for the dev root.
# Keep MODEL_ID and Bedrock IAM resources aligned:
# - bedrock_model_id is passed to the Lambda MODEL_ID environment variable.
# - bedrock_foundation_model_id and destination regions build the allowed foundation-model ARNs.
#
# region = "eu-west-1"
#
# bedrock_model_id = "eu.anthropic.claude-haiku-4-5-20251001-v1:0"
# bedrock_foundation_model_id = "anthropic.claude-haiku-4-5-20251001-v1:0"
# bedrock_inference_profile_destination_regions = [
#   "eu-north-1",
#   "eu-west-3",
#   "eu-south-1",
#   "eu-south-2",
#   "eu-west-1",
#   "eu-central-1"
# ]
#
# chat_retention_days = 7
# max_context_chars = 24000
